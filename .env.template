# Production Environment Setup
# Copy to .env and fill in values

# ==========================================
# Server Configuration
# ==========================================
NODE_ENV=production
PORT=5000

# ==========================================
# Database (Railway auto-injects these)
# ==========================================
# For Railway: Don't set these manually, Railway injects automatically
# For local/VPS: Uncomment and fill in
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=mikrotik_config_builder
# DB_USER=postgres
# DB_PASSWORD=

# ==========================================
# Security - GENERATE SECURE KEYS!
# ==========================================
# These are REQUIRED - the server will not start without them
#
# Generate JWT_SECRET (64 bytes hex):
#   openssl rand -hex 64
#
# Generate ENCRYPTION_KEY (32 bytes hex):
#   openssl rand -hex 32
#
JWT_SECRET=
ENCRYPTION_KEY=

# JWT token expiry (default: 7 days)
JWT_EXPIRES=7d

# ==========================================
# CORS
# ==========================================
# Your public domain (no trailing slash)
CORS_ORIGIN=http://localhost:5173

# ==========================================
# Payment Gateways (Optional)
# ==========================================
# M-Pesa Daraja API
MPESA_CONSUMER_KEY=
MPESA_CONSUMER_SECRET=
MPESA_SHORTCODE=174379
MPESA_PASSKEY=
MPESA_CALLBACK_URL=
MPESA_ENVIRONMENT=sandbox
MPESA_PAYBILL=123456

# Stripe Payment Gateway
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_CURRENCY=usd

# PayPal Payment Gateway
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_ENVIRONMENT=sandbox
PAYPAL_WEBHOOK_ID=

# Flutterwave Payment Gateway
FLUTTERWAVE_SECRET_KEY=
FLUTTERWAVE_PUBLIC_KEY=
FLUTTERWAVE_ENCRYPTION_KEY=
FLUTTERWAVE_ENVIRONMENT=sandbox

# Bank Transfer Details
BANK_NAME=
BANK_ACCOUNT_NAME=
BANK_ACCOUNT_NUMBER=
BANK_BRANCH=
BANK_SWIFT=

# ==========================================
# Messaging (Optional)
# ==========================================
# Africa's Talking SMS
AT_API_KEY=
AT_USERNAME=sandbox
AT_SENDER_ID=MyISP

# WhatsApp Business API
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=

# ==========================================
# RADIUS (Optional)
# ==========================================
RADIUS_ENABLED=false
RADIUS_HOST=localhost
RADIUS_PORT=1812
RADIUS_SECRET=testing123

# ==========================================
# Logging
# ==========================================
LOG_LEVEL=info
ENABLE_MONITORING_API=false
ENABLE_ROUTER_CONNECTIVITY=false

# ==========================================
# Google OAuth
# ==========================================
# Get from: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
# Add to client/.env as: VITE_GOOGLE_CLIENT_ID=

# Error Monitoring (Sentry)
# ==========================================
# Get your DSN from: https://sentry.io
# Backend DSN (Node.js project)
SENTRY_DSN=

# Frontend DSN (React project)
# Add to client/.env as: VITE_SENTRY_DSN=
